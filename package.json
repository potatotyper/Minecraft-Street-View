{
  "scripts": {
    "start": "npm run build:viewer && node services/web-viewer/server.js",
    "viewer": "npm run build:viewer && node services/web-viewer/server.js",
    "serve:viewer": "node services/web-viewer/server.js",
    "build:viewer": "tsc -p services/web-viewer/tsconfig.json && vite build --config services/web-viewer/vite.config.ts",
    "test:viewer": "tsc -p services/web-viewer/tsconfig.test.json && node --test services/web-viewer/.test-dist/test/*.test.js"
  },
  "dependencies": {
    "busboy": "^1.6.0",
    "dotenv": "^17.4.2",
    "leaflet": "^1.9.4",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.21",
    "@types/node": "^25.6.0",
    "@types/three": "^0.184.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.10"
  }
}
